{
  "name": "@rljson/io-client",
  "version": "0.0.17",
  "description": "Rljson IO client library",
  "homepage": "https://github.com/rljson/io-client",
  "bugs": "https://github.com/rljson/io-client/issues",
  "private": false,
  "license": "MIT",
  "engines": {
    "node": ">=22.14.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rljson/io-client.git"
  },
  "main": "src/server/api.ts",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "pnpx vite build && tsc && node scripts/copy-readme-to-dist.js",
    "test": "pnpm installConformanceTests && pnpx vitest run --coverage && pnpm run lint",
    "prebuild": "npm run test",
    "prepublishOnly": "npm run build",
    "lint": "pnpx eslint",
    "updateGoldens": "cross-env UPDATE_GOLDENS=true pnpm test",
    "installConformanceTests": "node scripts/install-conformance-tests.js"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.9",
    "cross-env": "^10.1.0",
    "eslint": "^10.5.0",
    "eslint-plugin-jsdoc": "^63.0.7",
    "eslint-plugin-tsdoc": "^0.5.2",
    "get-port": "^7.2.0",
    "globals": "^17.7.0",
    "jsdoc": "^4.0.5",
    "nodemon": "^3.1.14",
    "read-pkg": "^10.1.0",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-node": "^6.0.0",
    "vite-plugin-dts": "^5.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9",
    "vitest-dom": "^0.1.1"
  },
  "dependencies": {
    "@rljson/hash": "^0.0.18",
    "@rljson/io": "^0.0.69",
    "@rljson/io-sqlite": "^0.0.18",
    "@rljson/is-ready": "^0.0.17",
    "@rljson/json": "^0.0.23",
    "@rljson/rljson": "^0.0.79",
    "@trpc/client": "^11.18.0",
    "@trpc/server": "^11.18.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "superjson": "^2.2.6",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {}
  },
  "packageManager": "pnpm@10.10.0"
}
